# Supabase — required
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI key encryption — server-side only (never use NEXT_PUBLIC_ prefix)
# Used by /api/ai-config to encrypt user API keys via the encrypt_api_key DB function.
# Generate with: openssl rand -base64 32
AI_ENCRYPTION_KEY=your-random-32-char-secret
